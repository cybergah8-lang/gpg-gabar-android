    <!-- Help -->
    <string name="help">Yardım</string>
    <string name="help_home_title">Hızlı Başlangıç</string>
    <string name="help_home_body">Şifrele, Şifreyi çöz veya bir metin dosyasının içeriğini şifrele.\nÖnce bir anahtar oluştur ya da içe aktar.\nGenel anahtarını paylaşmak için Dışa Aktar\u2019ı kullan.</string>
    <string name="help_create_key_title">Anahtar Oluşturma</string>
    <string name="help_create_key_body">1) Bir ad gir.\n2) Parola en az 100 karakter olmalı.\n3) Anahtarı oluştur ve parolayı güvenle sakla.\n\nNot: Parolayı kimseyle paylaşma.</string>
    <string name="help_import_title">Anahtar İçe Aktarma</string>
    <string name="help_import_body">1) Bir veya daha fazla .asc anahtar dosyası seç.\n2) Uygulama Genel ve Gizli anahtarları otomatik algılar.\n3) İstenirse parolayı gir.\n4) Anahtar otomatik olarak listeye eklenir.</string>
    <string name="help_export_title">Anahtar Dışa Aktarma</string>
    <string name="help_export_body">1) Dışa aktarılacak anahtarları seç.\n2) Yalnızca Genel veya Genel + Gizli seç.\n3) Kaydetme konumunu seç.\n4) Gerekirse parolayı gir.\n5) Dosyalar name-public.asc ve name-secret.asc olarak kaydedilir.</string>
    <string name="help_encrypt_file_title">Dosya Şifreleme (.gpg)</string>
    <string name="help_encrypt_file_body">1) Şifrelenecek dosyayı seç.\n2) Bir veya daha fazla Genel anahtar seç.\n3) Kaydetme konumunu seç.\n4) Çıktı .gpg olarak kaydedilir.\n\nÇözmek için karşılık gelen Gizli anahtar ve parola gerekir.</string>
    <string name="help_decrypt_file_title">Dosya Şifre Çözme</string>
    <string name="help_decrypt_file_body">1) .gpg veya .pgp uzantılı bir dosya seç.\n2) Uygulama, varsa özel anahtarı arar ve tanır; şifre çözme sürecini yönlendirir.\n3) Anahtar uygulamada kayıtlıysa parola istemez.\n4) Çözülen dosyanın kaydedileceği yeri seç.</string>
    <string name="help_text_title">Metin Şifreleme / Çözme</string>
    <string name="help_text_body">1) Metin yaz veya bir metin dosyası aç.\n2) Anahtar(lar) seç.\n3) Metni şifrele veya çöz.\n4) İstenirse parolayı gir.\n\nKaydet, metni .txt olarak kaydeder.</string>
    <string name="help_delete_title">Anahtar Silme</string>
    <string name="help_delete_body">1) Silmek istediğin anahtarları seç.\n2) Silmeyi onayla.\n\nNot: Bu işlem geri alınamaz.</string>

