<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Disallow cleartext and ignore user-added CA certificates (harder MITM). -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
