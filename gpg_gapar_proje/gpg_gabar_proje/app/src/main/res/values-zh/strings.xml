    <string name="app_name">GPG Gabar</string>
    <string name="share_activity_label">加密 - 解密</string>

    <!-- About -->
    <string name="about_label">关于</string>
    <string name="about_title">关于 GPG Gabar</string>
    <string name="about_text">本程序为纪念库尔德自由游击队与土耳其国家之间战争中的一位英雄而开发：扎普罗贾瓦一侧“Şehid Delil”州指挥部成员、Hêzên Taybet 的费代伊指挥官——Şehid Gabar Botan - Abdurrahim Erzen。\n\nGPG Gabar 程序基于 PGP（Pretty Good Privacy），旨在让其在 ANDROID 手机和平板上轻松且安全地运行。程序的主要目标是让用户能够安全地加密与解密他们的文件与文本。所有功能均经过全面测试，以确保高可信度与性能。\n\n为达到高等级安全性，密钥用户的密码必须非常强，并且至少包含 100 个字符。不满足该要求的密码将不会被应用接受。\n\n我们希望本程序能帮助你发展安全通信并管理加密数据。\n\nGPG Gabar 程序由 Cybergah 团队准备。\n\n祝所有用户成功…</string>

    <!-- Help -->
    <string name="help">帮助</string>
    <string name="help_home_title">快速开始</string>
    <string name="help_home_body">使用加密、解密，或加密文本文件内容。\n先创建或导入密钥。\n使用导出来分享公钥。</string>
    <string name="help_create_key_title">创建密钥</string>
    <string name="help_create_key_body">1) 输入名称。\n2) 设置不少于 100 个字符的密码。\n3) 创建密钥并妥善保存密码。\n\n不要分享密码。</string>
    <string name="help_import_title">导入密钥</string>
    <string name="help_import_body">1) 选择一个或多个 .asc 密钥文件。\n2) 应用会识别公钥和私钥。\n3) 如提示请输入密码。\n4) 密钥会自动添加到列表。</string>
    <string name="help_export_title">导出密钥</string>
    <string name="help_export_body">1) 选择要导出的密钥。\n2) 选择 仅公钥 或 公钥+私钥。\n3) 选择保存位置。\n4) 如提示请输入口令。\n5) 文件将保存为 name-public.asc 和 name-secret.asc。</string>
    <string name="help_encrypt_file_title">加密文件 (.gpg)</string>
    <string name="help_encrypt_file_body">1) 选择要加密的文件。\n2) 选择一个或多个公钥。\n3) 选择保存加密结果的位置。\n4) 输出会保存为 .gpg 文件。\n\n解密需要对应的私钥和口令。</string>
    <string name="help_decrypt_file_title">解密文件</string>
    <string name="help_decrypt_file_body">1) 选择 .gpg 或 .pgp 文件。\n2) 应用会查找并识别私钥（如有），并引导解密过程。\n3) 如果密钥已保存在应用中，将不会要求输入密码。\n4) 选择解密后文件的保存位置。</string>
    <string name="help_text_title">加密 / 解密文本</string>
    <string name="help_text_body">1) 输入文本或打开文本文件。\n2) 选择密钥。\n3) 加密或解密文本。\n4) 如提示请输入密码。\n\n保存会将当前内容保存为 .txt 文件。</string>
    <string name="help_delete_title">删除密钥</string>
    <string name="help_delete_body">1) 选择要删除的密钥。\n2) 确认删除。\n\n注意：无法撤销。</string>

